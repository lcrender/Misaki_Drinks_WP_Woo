# ========================================
# Misaki Drinks — variables de PRODUCCIÓN
# ========================================
# Servidor: /opt/misakidrinks
# Copiar en el servidor: cp .env.production.example .env
# Editar TODOS los valores marcados como change_me antes de levantar el stack.
#
# Local (desarrollo): usar .env.example + docker-compose.yml
# ========================================

# ——— Base de datos MySQL ———
WORDPRESS_DB_NAME=misakidrinks
WORDPRESS_DB_USER=misaki_user
WORDPRESS_DB_PASSWORD=change_me_strong_db_password
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# ——— URLs del sitio (Traefik + HTTPS) ———
# Deben coincidir con el dominio canónico (sin www).
WP_HOME=https://misakidrinks.com
WP_SITEURL=https://misakidrinks.com

# ——— Acceso temporal al sitio (Traefik Basic Auth) ———
# Generar hash: htpasswd -nbB usuario 'password'
# IMPORTANTE: reemplazar cada "$" por "$$" para usarlo en .env/Compose.
# Ejemplo:
# TRAEFIK_BASIC_AUTH_USERS=cliente:$$2y$$05$$abc...
TRAEFIK_BASIC_AUTH_USERS=change_me_basic_auth_user_and_hash

# ——— WordPress salts (recomendado en producción) ———
# Generar valores únicos en: https://api.wordpress.org/secret-key/1.1/salt/
# Si se dejan vacíos, wp-config.php usará los fallbacks del repo (no recomendado en prod).
WORDPRESS_AUTH_KEY=
WORDPRESS_SECURE_AUTH_KEY=
WORDPRESS_LOGGED_IN_KEY=
WORDPRESS_NONCE_KEY=
WORDPRESS_AUTH_SALT=
WORDPRESS_SECURE_AUTH_SALT=
WORDPRESS_LOGGED_IN_SALT=
WORDPRESS_NONCE_SALT=

# ——— Debug (dejar vacío o 0 en producción) ———
WORDPRESS_DEBUG=

# ——— Prefijo de tablas (solo cambiar en instalaciones nuevas) ———
WORDPRESS_TABLE_PREFIX=wp_
